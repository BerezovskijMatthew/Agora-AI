# ─────────────────────────────────────────────────────────────────────────────
# Agora-AI · Dockerfile
# Запускает приложение в веб-режиме Flet (без графического дисплея)
# Доступ: http://localhost:8080
# ─────────────────────────────────────────────────────────────────────────────

# Базовый образ: официальный Python 3.12 slim (минимальный размер)
FROM python:3.12-slim

# ── Метаданные ────────────────────────────────────────────────────────────────
LABEL maintainer="Agora-AI"
LABEL description="Agora-AI — чат-приложение с ИИ-ассистентом на Flet + Groq"
LABEL version="2.0"

# ── Переменные окружения ──────────────────────────────────────────────────────
# API-ключ Groq — передавать при запуске через -e GROQ_API_KEY=...
# НЕ вписывайте реальный ключ в Dockerfile
ENV GROQ_API_KEY=""

# Отключить буферизацию вывода Python (логи сразу в stdout)
ENV PYTHONUNBUFFERED=1

# Не создавать .pyc файлы
ENV PYTHONDONTWRITEBYTECODE=1

# Рабочая директория внутри контейнера
WORKDIR /app

# ── Системные зависимости ─────────────────────────────────────────────────────
# Flet в веб-режиме требует: curl (healthcheck) + libglib2.0 (Flutter runtime)
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl \
        libglib2.0-0 \
        libgl1 \
    && rm -rf /var/lib/apt/lists/*

# ── Python-зависимости ────────────────────────────────────────────────────────
# Копируем requirements отдельно — Docker кэширует этот слой,
# и при изменении только main.py зависимости не переустанавливаются
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# ── Исходный код ──────────────────────────────────────────────────────────────
COPY main.py .

# ── Том для базы данных ───────────────────────────────────────────────────────
# Данные SQLite сохраняются между перезапусками контейнера
VOLUME ["/app/data"]

# Переопределяем путь к БД через переменную окружения
ENV DB_PATH=/app/data/agora_ai.db

# ── Порт ─────────────────────────────────────────────────────────────────────
EXPOSE 8080

# ── Проверка работоспособности ────────────────────────────────────────────────
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:8080 || exit 1

# ── Запуск ────────────────────────────────────────────────────────────────────
# Flet web-режим: приложение запускается как HTTP-сервер без GUI
CMD ["python", "-m", "flet", "run", "main.py", \
     "--web", "--host", "0.0.0.0", "--port", "8080"]
